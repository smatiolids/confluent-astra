{
  "name": "${CONNECTOR_NAME}",
  "config": {
    "connector.class": "com.datastax.oss.kafka.sink.CassandraSinkConnector",
    "tasks.max": "1",
    "topics": "${KAFKA_TOPIC}",
    "cloud.secureConnectBundle": "/opt/kafka-connect/datastax-astra/secure-connect-bundle.zip",
    "auth.username": "token",
    "auth.password": "${ASTRA_TOKEN}",
    "insert.mode": "insert",
    "topic.${KAFKA_TOPIC}.${ASTRA_DB_KEYSPACE}.messages.mapping": "id=value.id,event_time=value.event_time,payload=value.payload",
    "topic.${KAFKA_TOPIC}.${ASTRA_DB_KEYSPACE}.messages.consistencyLevel": "LOCAL_QUORUM",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false"
  }
}
